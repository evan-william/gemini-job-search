{
  "name": "gemini-job-search-os",
  "version": "0.1.0",
  "description": "Open-source career radar for turning a CV and public job sources into ranked matches, proof gaps, portfolio moves, outreach drafts, and interview prep.",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "gemini-job-search-os": "src/cli.js"
  },
  "scripts": {
